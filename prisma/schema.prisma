generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  hashedPassword String
  createdAt      DateTime  @default(now())
  products       Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  category    String
  description String?
  createdAt   DateTime @default(now())
  authorEmail String?
  author      User?    @relation(fields: [authorEmail], references: [email])
}
